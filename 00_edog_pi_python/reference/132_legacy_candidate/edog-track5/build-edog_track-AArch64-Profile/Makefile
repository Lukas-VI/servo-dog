	@test -d $(DISTDIR) || mkdir -p $(DISTDIR)
	$(COPY_FILE) --parents $(DIST) $(DISTDIR)/
	$(COPY_FILE) --parents ../../qt-everywhere-src-5.12.8/Qt-5.12.8-arm64/mkspecs/features/data/dummy.cpp $(DISTDIR)/
