	$(COPY_FILE) --parents ../edog_track4/main.cpp ../edog_track4/lcmutil.cpp ../edog_track4/colorgroup.cpp ../edog_track4/mythread.cpp ../edog_track4/udputil.cpp ../edog_track4/bridge.cpp $(DISTDIR)/


